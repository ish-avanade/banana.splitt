# banana/splitt environment variables
# Copy this file to .env and fill in your values

# Server port (default: 3000)
# PORT=3000

# ── AI provider (choose ONE: Azure OpenAI OR direct OpenAI) ──

# Option 1: Azure OpenAI (via Azure AI Foundry)
# Find these in Azure AI Foundry → Management → Keys and Endpoint
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-deployment
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Option 2: Direct OpenAI
# Get yours at https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
